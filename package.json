{
  "name": "web-tech-projekt-frontend",
  "version": "1.0.0",
  "description": "Frontend Repository für das Web-Tech Projekt",
  "homepage": "https://github.com/AlexanderKalinin-HTW/Web-Tech-Projekt-Frontend#readme",
  "bugs": {
    "url": "https://github.com/AlexanderKalinin-HTW/Web-Tech-Projekt-Frontend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlexanderKalinin-HTW/Web-Tech-Projekt-Frontend.git"
  },
  "license": "ISC",
  "author": "Alexander Kalinin, Ben Bartoschik",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --noEmit -p tsconfig.vitest.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-modules-commonjs": "^7.28.6",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0"
  }
}
